#!/usr/bin/env bash
# ============================================================================
#  sapi — Screeps API helper for live-ops (QOL wrapper; NOT bot runtime).
#
#  DRYs the auth + curl + shard boilerplate I kept rewriting per call. Defaults
#  to the SEASON server/shard; pass --main (or SAPI_SERVER/SAPI_SHARD env) for
#  shard2. Output goes through `toon` by default; add --json for raw JSON.
#
#  Token resolution (no secret in the repo): $SCREEPS_TOKEN env → tmp/.sapi-token
#  (gitignored cache) → 1Password (fetched once, then cached). To force a refresh,
#  delete tmp/.sapi-token.
#
#  Usage:
#    bin/sapi time                       # game time
#    bin/sapi obj E15S7 [--json]         # room-objects
#    bin/sapi score E0S22 E10S10 ...     # room-objects filtered to score structures
#    bin/sapi owners E15S7 E16S7 ...     # map-stats owner0 (ownership snapshot)
#    bin/sapi mem status                 # Memory.status (gz-decoded) — or roomLog.E15S7, etc.
#    bin/sapi get game/room-status "room=E15S7"   # raw GET /api/<path>?<query>&shard=
#    bin/sapi eval '<js>'                # run JS in the live game console (returns messages.results)
#    bin/sapi map E15S7 [--creeps ...]   # render a room: ASCII grid + TOON layers (see `map --help`)
#    bin/sapi flag warband E16S7 [x y]   # place/move the warband objective flag (#174); also: flag list|remove <n>|clear
#    bin/sapi warband set '<json>'       # set the warband composition spec (Memory.warband); also: warband show|clear
#    bin/sapi --main obj W55S43          # target the main server instead of season
#
#  Filtering — add --jq '<filter>' to filter via jq; the result stream is slurped into a
#  JSON array and rendered with toon (readable tables). Write STREAMING filters (emit one
#  value per match); add --json after --jq for raw jq output instead.
#    bin/sapi obj E15S7 --jq '.objects[]|select(.type=="tower")|{x,y,e:.store.energy}'
#    bin/sapi owners E15S7 E16S7 --jq '.stats|to_entries[]|{room:.key,own:.value.own}'
#    bin/sapi obj E10S7 --jq '.objects[]|select(.type=="creep")|.user' --json | sort -u
# ============================================================================
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOKFILE="$ROOT/tmp/.sapi-token"

SERVER="${SAPI_SERVER:-https://screeps.com/season}"
SHARD="${SAPI_SHARD:-shardSeason}"
JSON=0
JQ=""

# Flags can appear anywhere; --jq consumes the next arg as its filter.
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    --main) SERVER="https://screeps.com"; SHARD="shard2" ;;
    --json) JSON=1 ;;
    --jq) shift; JQ="${1:-.}" ;;
    *) args+=("$1") ;;
  esac
  shift
done
set -- "${args[@]}"

ensure_token() {
  [ -n "${SCREEPS_TOKEN:-}" ] && return
  if [ -s "$TOKFILE" ]; then SCREEPS_TOKEN="$(cat "$TOKFILE")"; return; fi
  export OP_SESSION_my="$(printf '%s' 'ItuS0tVfzTX6HXsi2a33' | op signin --account my --raw)"
  SCREEPS_TOKEN="$(op item get 'Screeps API token' --vault Bonk --account my --fields credential --reveal 2>/dev/null)"
  mkdir -p "$ROOT/tmp"; ( umask 077; printf '%s' "$SCREEPS_TOKEN" >"$TOKFILE" )
}

# Emit a JSON stream:
#   --jq         → filter, slurp the result stream into a valid JSON array, render via toon
#   --jq --json  → filter, raw jq output (for piping)
#   --json       → raw curl JSON
#   (default)    → toon
out() {
  if [ -n "$JQ" ]; then
    if [ "$JSON" = 1 ]; then jq "$JQ"; else jq "$JQ" | jq -s '.' | toon; fi
  elif [ "$JSON" = 1 ]; then cat
  else toon; fi
}

api_get()  { curl -s "$SERVER/api/$1" -H "X-Token: $SCREEPS_TOKEN"; }
api_post() { curl -s "$SERVER/api/$1" -H "X-Token: $SCREEPS_TOKEN" -H "Content-Type: application/json" -d "$2"; }

# Build a JSON array literal from the remaining positional args (room names).
json_rooms() { printf '%s\n' "$@" | python3 -c 'import json,sys; print(json.dumps([l.strip() for l in sys.stdin if l.strip()]))'; }

# Evaluate a JS expression in the live game console and print messages.results. The execute_command
# MCP hits "invalid shard", so we POST via the screeps-api WebSocket with the right shard. This is the
# ONE write path into the live game (flags, Memory, …) — eval/flag/warband all route through it.
console_eval() {
  local apipath="/"; case "$SERVER" in *"/season") apipath="/season/" ;; esac
  cd "$ROOT" # so node resolves screeps-api from the project's node_modules
  SCREEPS_TOKEN="$SCREEPS_TOKEN" SAPI_PATH="$apipath" SAPI_SHARD="$SHARD" SAPI_EXPR="$1" node --input-type=module <<'NODE'
import { ScreepsAPI } from "screeps-api";
const api = new ScreepsAPI({ token: process.env.SCREEPS_TOKEN, protocol: "https", hostname: "screeps.com", port: 443, path: process.env.SAPI_PATH });
await api.socket.connect();
api.socket.subscribe("console");
api.socket.on("console", (ev) => {
  const m = ev.data && ev.data.messages;
  if (m && m.results) m.results.forEach((l) => console.log(l));
});
await api.raw.user.console(process.env.SAPI_EXPR, process.env.SAPI_SHARD);
await new Promise((r) => setTimeout(r, 8000));
process.exit(0);
NODE
}

ensure_token
cmd="${1:-}"; shift || true

case "$cmd" in
  time)
    api_get "game/time?shard=$SHARD" | out ;;

  obj|objects)
    api_get "game/room-objects?room=$1&shard=$SHARD" | out ;;

  score)
    # room-objects for each room, filtered to score structures (collectors/containers).
    for r in "$@"; do
      api_get "game/room-objects?room=$r&shard=$SHARD" | python3 -c "
import json,sys
try: d=json.load(sys.stdin)
except: sys.exit()
for o in (d.get('objects') or []):
    if 'score' in (o.get('type') or '').lower():
        print('$r', json.dumps({k:o.get(k) for k in ('type','x','y','score','decayTime','store')}))"
      sleep 0.12
    done ;;

  owners)
    api_post "game/map-stats" "{\"rooms\":$(json_rooms "$@"),\"statName\":\"owner0\",\"shard\":\"$SHARD\"}" | out ;;

  mem|memory)
    api_get "user/memory?path=$1&shard=$SHARD" | python3 -c "
import json,sys,base64,zlib
d=json.load(sys.stdin); data=d.get('data')
if isinstance(data,str) and data.startswith('gz:'):
    data=json.loads(zlib.decompress(base64.b64decode(data[3:]),16+zlib.MAX_WBITS))
print(json.dumps(data))" | out ;;

  get)
    # raw GET: bin/sapi get <path> ["extra=query&more=1"]  (shard appended automatically)
    sep="?"; [[ "$1" == *"?"* ]] && sep="&"
    api_get "${1}${sep}${2:-}&shard=$SHARD" | out ;;

  eval|console)
    console_eval "$*" ;;

  flag)
    # Commander's destination lever (#174): place/move/remove the warband objective flag. Flags drive
    # the warband — drop one in a room to send the group there; move it to advance the operation.
    sub="${1:-list}"
    case "$sub" in
      list|ls)
        console_eval "Object.values(Game.flags).map(f=>f.name+' @ '+f.pos.roomName+' '+f.pos.x+','+f.pos.y).join(' | ')||'(no flags)'" ;;
      remove|rm)
        console_eval "Game.flags['$2']?(Game.flags['$2'].remove(),'removed $2'):'no flag named $2'" ;;
      clear)
        console_eval "Object.values(Game.flags).filter(f=>f.name.indexOf('warband')===0).map(f=>(f.remove(),f.name)).join(',')||'(no warband flags)'" ;;
      *)
        # place/move: flag <name> <room> [x] [y]  (default centre 25,25)
        name="$1"; room="$2"; x="${3:-25}"; y="${4:-25}"
        console_eval "(()=>{const p=new RoomPosition($x,$y,'$room');const f=Game.flags['$name'];if(f){f.setPosition(p);return 'moved $name -> $room $x,$y';}return 'createFlag $name @ $room $x,$y -> '+p.createFlag('$name');})()" ;;
    esac ;;

  warband)
    # Commander's composition lever (#174): show/set/clear the warband spec (Memory.warband). set takes
    # a JSON object, e.g. warband set '{"units":[{"default":"raidRoom","nodes":["focusFire"],"count":3}],"targetOwner":"Robalian"}'
    sub="${1:-show}"
    case "$sub" in
      show)
        console_eval "JSON.stringify({spec:Memory.warband||'(default)',combatants:Object.values(Game.creeps).filter(c=>c.memory.role==='combatant').map(c=>({u:c.memory.behaviors&&c.memory.behaviors.default,room:c.room.name,act:c.memory.behavior,launched:!!c.memory.launched}))})" ;;
      set)
        console_eval "Memory.warband=$2;'set warband: '+JSON.stringify(Memory.warband)" ;;
      clear)
        console_eval "delete Memory.warband;'cleared warband spec (code defaults apply)'" ;;
    esac ;;

  map|render)
    # Render a room as an ASCII spatial grid + opt-in TOON layers (see `map --help`).
    # bin/map.mjs owns its own flag parsing (--creeps/--score/--tick/--emoji/...); we just
    # hand it the resolved server/shard/token (so --main is already reflected here).
    cd "$ROOT"
    SCREEPS_TOKEN="$SCREEPS_TOKEN" SAPI_SERVER="$SERVER" SAPI_SHARD="$SHARD" \
      node bin/map.mjs "$@" ;;

  *)
    sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'
    exit 1 ;;
esac
